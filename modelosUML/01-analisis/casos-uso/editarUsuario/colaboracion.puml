@startuml editarUsuario-analisis
skinparam linetype polyline

' Contexto
rectangle #CDEBA5 ":USUARIO_ABIERTO" as UsuarioAbierto
rectangle #CDEBA5 ":Collaboration ConsultarUsuario" as ConsultarUsuarioColab

' Paquete del Caso de Uso
package editarUsuario as "editarUsuario()" {
    rectangle #629EF9 EditarUsuarioView
    rectangle #b5bd68 UsuarioController
    rectangle #F2AC4E UsuarioRepository
    rectangle #F2AC4E Usuario
}

' Flujo
UsuarioAbierto -r-> EditarUsuarioView: editarUsuario(usuario)

EditarUsuarioView -d-> UsuarioController: validarCambios(username, password, rol) : boolean

UsuarioController --> UsuarioRepository: verificarUnicidad(username) : boolean

EditarUsuarioView --> UsuarioController: guardarCambios(username, password, rol) : Usuario

UsuarioController --> UsuarioRepository: actualizar(usuario) : Usuario
UsuarioRepository -- Usuario

EditarUsuarioView ..> ConsultarUsuarioColab: <<include>> consultarUsuario(usuarioModificado)

@enduml