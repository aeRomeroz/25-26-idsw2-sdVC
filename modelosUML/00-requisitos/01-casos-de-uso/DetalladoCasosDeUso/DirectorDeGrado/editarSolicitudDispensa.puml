@startuml editarSolicitudDispensa_director
title Editar Solicitud de Dispensa
skinparam nodesep 100
skinparam ranksep 100
skinparam linetype ortho
skinparam Padding 10

state SOLICITUD_DISPENSA_ABIERTA_INICIAL as "SOLICITUD_DISPENSA_ABIERTA"
state SOLICITUD_DISPENSA_ABIERTA_FINAL   as "SOLICITUD_DISPENSA_ABIERTA"

[*] -[#green]-> SOLICITUD_DISPENSA_ABIERTA_INICIAL

SOLICITUD_DISPENSA_ABIERTA_INICIAL -[#green]-> EDITAR_SOLICITUD_DISPENSA : editarSolicitudDispensa()
note left on link
    <b>Director de Grado solicita</b> editar la solicitud.
    <b>Sistema presenta</b> los datos de la solicitud.
end note

state EDITAR_SOLICITUD_DISPENSA {
    state ModificarEstadoYDatos as "Modificación de Estado y Datos"

    [*] -[#green]-> ModificarEstadoYDatos

    note right of ModificarEstadoYDatos
        <b>Sistema muestra</b> los datos de la solicitud.
        <b>Director de Grado introduce:</b>
        • Estado (Aprobar/Rechazar).
        • Observaciones o motivo.
        • Otros campos editables.
    end note

    ModificarEstadoYDatos -[#green]-> [*]
}

EDITAR_SOLICITUD_DISPENSA -[#green]---> SOLICITUD_DISPENSA_ABIERTA_FINAL : guardarSolicitudDispensa()
note left on link
    <b>GUARDAR:</b>
    <b>Director de Grado solicita</b> guardar cambios.
    <b>Sistema registra</b> los cambios de la solicitud.
end note

EDITAR_SOLICITUD_DISPENSA -[#red]---> SOLICITUD_DISPENSA_ABIERTA_FINAL : cerrarSolicitudDispensa()
note right on link
    <b>CERRAR:</b>
    <b>Director de Grado solicita</b> salir.
    <b>Sistema descarta</b> los cambios introducidos.
end note

SOLICITUD_DISPENSA_ABIERTA_FINAL -[#blue]-> [*]
@enduml