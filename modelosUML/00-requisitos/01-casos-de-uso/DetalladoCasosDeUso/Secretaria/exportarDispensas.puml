@startuml exportarDispensas_secretaria
title Exportar Dispensas
skinparam nodesep 100
skinparam ranksep 100
skinparam linetype ortho
skinparam Padding 10

state DISPENSAS_ABIERTO_INICIAL as "DISPENSAS_ABIERTO"
state EXPORTACION_COMP          as "DISPENSAS_ABIERTO"
state DISPENSAS_ABIERTO_FINAL   as "DISPENSAS_ABIERTO"

[*] -[#green]-> DISPENSAS_ABIERTO_INICIAL

DISPENSAS_ABIERTO_INICIAL -[#green]-> EXPORTACION_COMP : exportarDispensas()
note left on link
    <b>Secretaría solicita</b> exportar las dispensas.
    <b>Sistema presenta</b> los parámetros de exportación.
end note

state EXPORTACION_COMP {
    state SeleccionParametros as "Selección de Parámetros"
    [*] -[#green]-> SeleccionParametros
    note right of SeleccionParametros
        <b>Secretaría introduce</b> sus preferencias:
        • Filtros (curso, asignatura, nombre, identificador).
        • Formato de salida (PDF, CSV).
        <b>Sistema presenta</b> el archivo generado.
    end note
    SeleccionParametros -[#green]-> [*]
}

EXPORTACION_COMP -[#green]---> DISPENSAS_ABIERTO_FINAL : exportarDispensas()
note left on link
    <b>EXPORTAR:</b>
    <b>Secretaría solicita</b> descargar el archivo.
    <b>Sistema muestra</b> el listado de dispensas.
end note

EXPORTACION_COMP -[#red]---> DISPENSAS_ABIERTO_FINAL : cancelarExportacion()
note right on link
    <b>CANCELAR:</b>
    <b>Secretaría solicita</b> cancelar la exportación.
    <b>Sistema descarta</b> los parámetros introducidos.
end note

DISPENSAS_ABIERTO_FINAL -[#blue]-> [*]

@enduml