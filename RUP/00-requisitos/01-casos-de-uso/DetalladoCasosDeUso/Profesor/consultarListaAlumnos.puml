@startuml consultarListaAlumnos
title Consultar Lista Alumnos
skinparam nodesep 100
skinparam ranksep 100
skinparam linetype ortho
skinparam Padding 10

state LISTAS_ABIERTO_INICIAL as "LISTAS_ABIERTO"
state LISTAS_ABIERTO_FINAL   as "LISTAS_ABIERTO"
state LISTA_ABIERTA_COMP     as "LISTA_ABIERTA"

[*] -[#green]-> LISTAS_ABIERTO_INICIAL

LISTAS_ABIERTO_INICIAL -[#green]-> LISTA_ABIERTA_COMP : consultarListaAlumnos()
note left on link
    <b>Profesor solicita</b> consultar la lista de alumnos de un curso.
    <b>Sistema presenta</b> la lista de alumnos.
end note

state LISTA_ABIERTA_COMP {
    state VisualizacionListado as "Visualización de Listado"
    [*] -[#green]-> VisualizacionListado
    note right of VisualizacionListado
        <b>Sistema muestra</b> la lista de alumnos matriculados:
        • Nombres, apellidos e identificadores.
        • Estado de la matrícula.
    end note
    VisualizacionListado -[#green]-> [*]
}

LISTA_ABIERTA_COMP -[#red]-> LISTAS_ABIERTO_FINAL : cerrarLista()
note left on link
    <b>Profesor solicita</b> salir de la lista.
    <b>Sistema muestra</b> el listado de listas de alumnos.
end note

LISTAS_ABIERTO_FINAL -[#blue]-> [*]

@enduml