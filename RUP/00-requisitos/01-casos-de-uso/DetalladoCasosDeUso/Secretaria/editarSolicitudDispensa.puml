@startuml editarSolicitudDispensa_secretaria
title Editar Solicitud de Dispensa
skinparam nodesep 100
skinparam ranksep 100
skinparam linetype ortho
skinparam Padding 10

state SOLICITUD_DISPENSA_ABIERTA_INICIAL as "SOLICITUD_DISPENSA_ABIERTA"
state EDICION_SOLICITUD_COMP            as "SOLICITUD_DISPENSA_ABIERTA"
state SOLICITUD_DISPENSA_ABIERTA_FINAL  as "SOLICITUD_DISPENSA_ABIERTA"

[*] -[#green]-> SOLICITUD_DISPENSA_ABIERTA_INICIAL

SOLICITUD_DISPENSA_ABIERTA_INICIAL -[#green]-> EDICION_SOLICITUD_COMP : editarSolicitudDispensa()
note left on link
    <b>Secretaría solicita</b> editar la solicitud de dispensa.
    <b>Sistema presenta</b> los datos de la solicitud.
end note

state EDICION_SOLICITUD_COMP {
    state EdicionDatos as "Edición de Datos"
    [*] -[#green]-> EdicionDatos
    note right of EdicionDatos
        <b>Sistema muestra</b> los datos de la solicitud.
        <b>Secretaría introduce</b> las modificaciones:
        • Motivo y documentación.
        • Otros campos editables.
    end note
    EdicionDatos -[#green]-> [*]
}

EDICION_SOLICITUD_COMP -[#green]---> SOLICITUD_DISPENSA_ABIERTA_FINAL : guardarSolicitudDispensa()
note left on link
    <b>GUARDAR:</b>
    <b>Secretaría solicita</b> guardar los cambios.
    <b>Sistema registra</b> los cambios de la solicitud.
end note

EDICION_SOLICITUD_COMP -[#red]---> SOLICITUD_DISPENSA_ABIERTA_FINAL : cerrarSolicitudDispensa()
note right on link
    <b>CERRAR:</b>
    <b>Secretaría solicita</b> salir sin guardar.
    <b>Sistema descarta</b> los cambios introducidos.
end note

SOLICITUD_DISPENSA_ABIERTA_FINAL -[#blue]-> [*]

@enduml