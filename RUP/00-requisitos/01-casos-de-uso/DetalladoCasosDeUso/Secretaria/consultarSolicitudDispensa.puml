@startuml consultarSolicitudDispensa_secretaria
title Consultar Solicitud Dispensa
skinparam nodesep 100
skinparam ranksep 100
skinparam linetype ortho
skinparam Padding 10

state DISPENSAS_ABIERTO_INICIAL       as "DISPENSAS_ABIERTO"
state SOLICITUD_DISPENSA_ABIERTA_COMP as "SOLICITUD_DISPENSA_ABIERTA"
state DISPENSAS_ABIERTO_FINAL         as "DISPENSAS_ABIERTO"

[*] -[#green]-> DISPENSAS_ABIERTO_INICIAL

DISPENSAS_ABIERTO_INICIAL -[#green]-> SOLICITUD_DISPENSA_ABIERTA_COMP : consultarSolicitudDispensa()
note left on link
    <b>Secretaría solicita</b> consultar el detalle de una solicitud.
    <b>Sistema presenta</b> el detalle de la solicitud.
end note

state SOLICITUD_DISPENSA_ABIERTA_COMP {
    state VisualizacionDetalle as "Visualización de Detalle"
    [*] -[#green]-> VisualizacionDetalle
    note right of VisualizacionDetalle
        <b>Sistema muestra</b> los datos de la solicitud.
        <b>Sistema permite solicitar</b> editarSolicitudDispensa().
    end note
    VisualizacionDetalle -[#green]-> [*]
}

SOLICITUD_DISPENSA_ABIERTA_COMP -[#green]---> DISPENSAS_ABIERTO_FINAL : guardarSolicitudDispensa()
note left on link
    <b>GUARDAR:</b>
    <b>Secretaría solicita</b> guardar los cambios.
    <b>Sistema registra</b> los cambios de la solicitud.
end note

SOLICITUD_DISPENSA_ABIERTA_COMP -[#red]---> DISPENSAS_ABIERTO_FINAL : cerrarSolicitud()
note right on link
    <b>CERRAR:</b>
    <b>Secretaría solicita</b> salir del detalle.
    <b>Sistema muestra</b> el listado de dispensas.
end note

DISPENSAS_ABIERTO_FINAL -[#blue]-> [*]

@enduml